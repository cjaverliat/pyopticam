# ---------------------------------------------------------------------------
# CameraManager
# ---------------------------------------------------------------------------

class CameraManagerListener:
    def CameraConnected(self) -> None: ...
    def CameraRemoved(self) -> None: ...
    def CameraInitialized(self) -> None: ...

class CameraManager:
    """Singleton managing all connected OptiTrack cameras. Access via CameraManager.X()."""
    @staticmethod
    def X() -> CameraManager: ...
    @staticmethod
    def Ptr() -> CameraManager: ...
    @staticmethod
    def IsActive() -> bool: ...
    @staticmethod
    def DestroyInstance() -> None: ...
    def WaitForInitialization(self) -> bool: ...
    def AreCamerasInitialized(self) -> bool: ...
    def AreCamerasShutdown(self) -> bool: ...
    def Shutdown(self) -> None: ...
    def GetCameraBySerial(self, serial: int) -> Optional[Camera]: ...
    def GetCamera(self, uid: Optional[cUID] = None) -> Optional[Camera]: ...
    def GetCameraList(self, list: CameraList) -> None: ...
    def GetHardwareKey(self) -> Optional[Camera]: ...
    def GetDevice(self, uid: cUID) -> Optional[Camera]: ...
    def ScanForCameras(self) -> None: ...
    def RegisterListener(self, listener: CameraManagerListener) -> None: ...
    def UnregisterListener(self) -> None: ...
    def AddCamera(self, camera: Camera) -> None: ...
    def RemoveCamera(self, camera: Camera) -> None: ...
    def SoftwareTrigger(self) -> None: ...
    def TimeStamp(self) -> float: ...
    @staticmethod
    def CameraFactory(revision: int, init: bool = True, serial: int = 0) -> Camera: ...

# ---------------------------------------------------------------------------
# cModuleSync
# ---------------------------------------------------------------------------

class cModuleSync:
    """Frame synchronizer that groups frames from multiple cameras."""
    @staticmethod
    def Create() -> cModuleSync: ...
    @staticmethod
    def Destroy(sync: cModuleSync) -> None: ...
    def AddCamera(self, camera: Camera) -> None: ...
    def RemoveAllCameras(self) -> None: ...
    def CameraCount(self) -> int: ...
    def GetFrameGroup(self) -> Optional[FrameGroup]: ...
    def LastFrameGroupMode(self) -> Modes: ...
    def AllowIncompleteGroups(self) -> bool: ...
    def SetAllowIncompleteGroups(self, allow: bool) -> None: ...
    def SetOptimization(self, opt: eOptimization) -> None: ...
    def Optimization(self) -> eOptimization: ...
    def SetSuppressOutOfOrder(self, suppress: bool) -> None: ...
    def FrameDeliveryRate(self) -> float: ...
    def PostFrame(self, frame: Frame) -> None: ...

