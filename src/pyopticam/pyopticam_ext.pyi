"""Type stubs for pyopticam_ext — OptiTrack Camera SDK Python bindings."""

from __future__ import annotations
from enum import Enum
from typing import Optional
import numpy as np

# ---------------------------------------------------------------------------
# Enums
# ---------------------------------------------------------------------------

class eVideoMode(Enum):
    """Camera video output mode."""
    SegmentMode: eVideoMode
    GrayscaleMode: eVideoMode
    ObjectMode: eVideoMode
    InterleavedGrayscaleMode: eVideoMode
    PrecisionMode: eVideoMode
    BitPackedPrecisionMode: eVideoMode
    MJPEGMode: eVideoMode
    VideoMode: eVideoMode
    SynchronizationTelemetry: eVideoMode
    UnknownMode: eVideoMode

class eImagerGain(Enum):
    """Imager gain level."""
    Gain_Level0: eImagerGain
    Gain_Level1: eImagerGain
    Gain_Level2: eImagerGain
    Gain_Level3: eImagerGain
    Gain_Level4: eImagerGain
    Gain_Level5: eImagerGain
    Gain_Level6: eImagerGain
    Gain_Level7: eImagerGain

class eCameraState(Enum):
    """Camera initialization state."""
    Uninitialized: eCameraState
    InitializingDevice: eCameraState
    InitializingCamera: eCameraState
    Initializing: eCameraState
    WaitingForChildDevices: eCameraState
    WaitingForDeviceInitialization: eCameraState
    Initialized: eCameraState
    Disconnected: eCameraState
    Shutdown: eCameraState

class eStatusLEDs(Enum):
    """Camera status LED selector."""
    GreenStatusLED: eStatusLEDs
    RedStatusLED: eStatusLEDs
    CaseStatusLED: eStatusLEDs
    IlluminationLED: eStatusLEDs

class eOptimization(Enum):
    ForceTimelyDelivery: eOptimization
    FavorTimelyDelivery: eOptimization
    ForceCompleteDelivery: eOptimization
    eOptimizationCount: eOptimization

class Modes(Enum):
    """FrameGroup synchronization mode."""
    none: Modes
    Software: Modes
    Hardware: Modes

# ---------------------------------------------------------------------------
# Simple data types
# ---------------------------------------------------------------------------

class sStatusLightColor:
    Red: int
    Green: int
    Blue: int

class cUID:
    def SetValue(self, high: int, low: int) -> None: ...
    def LowBits(self) -> int: ...
    def HighBits(self) -> int: ...
    def Valid(self) -> bool: ...
